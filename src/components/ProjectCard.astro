---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Location from './icons/Location.astro';

interface Props {
  image: ImageMetadata;
  title?: string;
  category: string;
  tags: string[];
  location: string;
}

const { image, title, category, tags, location } = Astro.props;
---

<div class="project-card shrink-0 isolate transition-all duration-500 ease-in-out">
  <div class="card-image-wrapper w-full relative overflow-hidden transition-all duration-500 ease-in-out">
    <Image
      src={image}
      alt={title ?? category}
      width={700}
      class="w-full h-full md:h-[65vh] object-cover block"
      loading="lazy"
    />
    <div class="card-gradient absolute bottom-0 inset-x-0 p-4 md:pb-10 md:pl-10">
      <div class="flex items-center gap-3 mb-2">
        <span class="text-secondary text-xs font-poppins border border-secondary/50 px-2 py-0.5 md:text-lg">{category}</span>
      </div>
      <div class="flex gap-3 mb-1.5">
        {tags.map((tag) => (
          <span class="font-poppins text-secondary text-xs md:text-lg">+ {tag}</span>
        ))}
      </div>
      <div class="flex items-center gap-1.5">
        <Location color='white'/>
        <span class="font-poppins text-secondary text-xs md:text-lg">{location}</span>
      </div>
    </div>
  </div>
</div>

<style>
  .card-image-wrapper {
    clip-path: inset(0);
    height: 65vw;
    width: 60vw;
  }

  @media (min-width: 768px) {
    .card-image-wrapper { height: 50vh; width: 14vw; }
    .project-card.is-active .card-image-wrapper { width: 60vw; }
  }

  @media (min-width: 1280px) {
    .card-image-wrapper { height: 65vh; width: 10vw; }
    .project-card.is-active .card-image-wrapper { width: 30vw; }
  }

  .card-gradient {
    background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.4) 60%, rgba(0,0,0,0) 100%);
  }

  /* Ocultar texto en cards inactivas */
  .project-card:not(.is-active) .card-gradient {
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .project-card.is-active .card-gradient {
    opacity: 1;
    transition: opacity 0.3s ease 0.2s;
  }
</style>
