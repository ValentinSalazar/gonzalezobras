---
import Location from "../icons/Location.astro";
import Phone from "../icons/Phone.astro";
import TitleSection from "../TitleSection.astro";
---

<section class="relative h-auto w-full px-5 pt-5 md:w-1/2 overflow-hidden">
    <span class="hidden md:flex w-20 h-1.25 mb-2"></span>
    <TitleSection
        title="Nosotros"
        color="first"
        subtitle="quienes somos"
        mas_color="first"
        title_size="text-5xl"
    />
    <div class="pt-5 flex flex-col gap-5 font-extralight">
        <p>
            Con más de <b>8 años</b> de experiencia y <b
                >150 obras concretadas</b
            >, somos especialistas en construcción en seco.
        </p>
        <p>
            Optimizamos tiempos y recursos para <b>transformar espacios</b> con precisión,
            limpieza y calidad garantizada.
        </p>
        <p>
            Operamos desde <b>San Pedro</b>, brindando cobertura integral en <b
                >CABA</b
            >, <b>Provincia de Buenos Aires</b> y el resto del país.
        </p>
    </div>
    <ul class="mt-5 font-extralight">
        <li class="flex gap-3 items-center">
            <Location />
            <h3 >San Pedro, Buenos Aires</h3>
        </li>
        <li class="flex gap-3 items-center">
            <Phone />
            <a
                href="https://wa.me/3329335202?text=Hola%2C%20quiero%20consultar%20por%20un%20presupuesto"
                target="_blank"
                aria-label="Contactar por WhatsApp">+54 3329 335202</a
            >
        </li>
    </ul>
    <div class="mt-8">
        <div
            id="map-placeholder"
            data-src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d53808.77!2d-59.69!3d-33.685!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x95b767a43d5d82ef%3A0x74b8e4b7f39a7b0!2sSan%20Pedro%2C%20Buenos%20Aires%2C%20Argentina!5e0!3m2!1ses!2sar!4v1"
            style="width:100%;height:200px;background:#e5e7eb;"
        ></div>
    </div>

    <script>
        const placeholder = document.getElementById('map-placeholder');
        if (placeholder) {
            const observer = new IntersectionObserver((entries) => {
                if (entries[0].isIntersecting) {
                    const iframe = document.createElement('iframe');
                    iframe.src = placeholder.dataset.src!;
                    iframe.width = '100%';
                    iframe.height = '200';
                    iframe.style.border = '0';
                    iframe.allowFullscreen = true;
                    iframe.loading = 'lazy';
                    iframe.referrerPolicy = 'no-referrer-when-downgrade';
                    iframe.title = 'Ubicación de González Obras en San Pedro, Buenos Aires';
                    placeholder.replaceWith(iframe);
                    observer.disconnect();
                }
            }, { rootMargin: '200px' });
            observer.observe(placeholder);
        }
    </script>

    <div class="absolute bottom-0 left-0 right-0 pointer-events-none select-none overflow-hidden z-[-1]">
        <div
            class="flex flex-col font-bebas text-[100px] md:text-8xl leading-tight whitespace-nowrap"
            style="background: linear-gradient(to bottom, #4E4B4B 0%, #1E1E1E 53%, #FFFFFF 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; opacity: 0.03;"
        >
            <span>NOSOTROS</span>
            <span>CIELORRASOS</span>
            <span>AMOBLAMIENTOS</span>
            <span>REVESTIMIENTOS</span>
            <span>CONSTRUCCIONN</span>
            <span>ESPECIALISTAS</span>
            <span>OPTIMIZAMOS</span>
            <span>TRANSFORMACION</span>
        </div>
    </div>
</section>
