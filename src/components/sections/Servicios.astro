---
import TitleSection from "../TitleSection.astro";

const servicios = [
    {
        number: "01",
        title: "Wall Panel",
        description: "Instalación de paneles decorativos para interiores y exteriores, con acabados modernos y duraderos.",
        gallery: ["/projects/proyectos01.webp", "/projects/proyectos02.webp", "/projects/proyectos03.webp"],
    },
    {
        number: "02",
        title: "PVC",
        description: "Techos y revestimientos de PVC resistentes a la intemperie, livianos y de bajo mantenimiento. Ideales para obras residenciales y comerciales.",
        gallery: ["/projects/proyectos01.webp", "/projects/proyectos02.webp"],
    },
    {
        number: "03",
        title: "Cielorrasos",
        description: "Cielorrasos desmontables, continuos y con gargantas, con estructura metálica y placas de yeso. Acabados perfectos para todo tipo de ambientes.",
        gallery: ["/projects/proyectos01.webp", "/projects/proyectos02.webp"],
    },
    {
        number: "04",
        title: "Amoblamientos",
        description: "Muebles a medida en melamina y madera maciza con herrajes importados. Cocinas, placards y dormitorios equipados con materiales de primera.",
        gallery: ["/projects/proyectos01.webp", "/projects/proyectos02.webp"],
    },
    {
        number: "05",
        title: "Revestimientos",
        description: "Revestimientos interiores y exteriores con materiales de primera calidad. Cerámicas, porcellanatos y sistemas de fachada ventilada.",
        gallery: ["/projects/proyectos01.webp", "/projects/proyectos02.webp"],
    },
    {
        number: "06",
        title: "Tabiques y Paredes Divisorias",
        description: "Construcción de tabiques y paredes divisorias en seco con estructura metálica y placas de yeso o cemento. Soluciones rápidas para dividir y reorganizar espacios residenciales y comerciales.",
        gallery: ["/projects/proyectos01.webp", "/projects/proyectos02.webp"],
    },
    {
        number: "07",
        title: "Trabajos de Exterior",
        description: "Intervenciones en fachadas, terrazas y espacios exteriores con materiales resistentes a la intemperie. Revestimientos, cielorrasos exteriores y terminaciones de alta durabilidad.",
        gallery: ["/projects/proyectos01.webp", "/projects/proyectos02.webp"],
    },
    {
        number: "08",
        title: "Cajones y Cortineros",
        description: "Fabricación e instalación de cajones y cortineros a medida integrados al diseño del espacio. Acabados prolijos en melamina o madera para todo tipo de ambientes.",
        gallery: ["/projects/proyectos01.webp", "/projects/proyectos02.webp"],
    },
];
---

<section class="relative w-screen h-auto">
    <div class="absolute inset-0 bg-cover bg-center bg-no-repeat" style="background-image: url('/projects/proyectos01.webp');"></div>
    <div class="absolute inset-0 bg-black/75"></div>

    <div class="relative z-10 px-5 py-8 md:flex md:gap-8 md:px-20 lg:px-24 xl:px-40 lg:py-10 lg:gap-16">
        <div class="md:w-1/2">
            <TitleSection title="Servicios" mas_color="first" subtitle="explorá lo que construimos" subtitle_color="white" title_size="text-5xl"/>

            <div class="mt-5 flex flex-col">
                {servicios.map((servicio, index) => (
                    <div class="accordion-item border-b border-white/30" data-index={index} data-gallery={JSON.stringify(servicio.gallery)}>
                        <button
                            class="accordion-header w-full flex items-center justify-between py-3"
                            aria-expanded={index === 0 ? "true" : "false"}
                        >
                            <div class="flex items-baseline gap-3">
                                <span class="font-bebas text-first text-lg lg:text-xl font-bold">{servicio.number}</span>
                                <span class="font-bebas text-white text-2xl lg:text-3xl">{servicio.title}</span>
                            </div>
                            <span class="accordion-icon font-bebas text-first text-2xl leading-none">
                                {index === 0 ? "−" : "+"}
                            </span>
                        </button>
                        <div class={`accordion-content overflow-hidden transition-all duration-300 ease-in-out ${index === 0 ? 'max-h-60' : 'max-h-0'}`}>
                            <p class="font-poppins font-light text-white text-sm pb-3 text-pretty">{servicio.description}</p>
                            <button class="gallery-btn font-poppins text-white text-sm italic flex justify-end pb-5 hover:text-first transition w-full md:hidden" data-title={servicio.title}>Ver galería</button>
                        </div>
                    </div>
                ))}
            </div>
        </div>

        <!-- Right column: Desktop gallery (hidden on mobile) -->
        <div class="hidden md:flex md:w-1/2 md:self-center md:h-[65vh] lg:h-[70vh]">
            <div class="w-full flex flex-col">
                <div class="relative overflow-hidden flex-1">
                    <div id="desktop-gallery-track" class="flex transition-transform duration-500 ease-in-out h-full cursor-grab">
                    </div>
                </div>
                <div id="desktop-gallery-dots" class="flex justify-center gap-3 mt-4"></div>
            </div>
        </div>
    </div>
</section>

<!-- Gallery Modal -->
<div id="gallery-modal" class="fixed inset-0 z-[100] hidden items-center justify-center">
    <div class="absolute inset-0 bg-black/90" id="gallery-overlay"></div>
    <div class="relative z-10 w-full h-full flex flex-col">
        <!-- Header -->
        <div class="flex items-center justify-between px-5 md:px-20 py-4">
            <h3 id="gallery-title" class="font-bebas text-white text-2xl"></h3>
            <button id="gallery-close" class="text-white hover:text-first transition" aria-label="Cerrar galería">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </button>
        </div>
        <!-- Image container -->
        <div class="flex-1 flex items-center justify-center relative overflow-hidden">
            <div id="gallery-track" class="flex transition-transform duration-500 ease-in-out h-full w-full">
            </div>
        </div>
        <!-- Controls -->
        <div class="flex items-center justify-center gap-6 py-4">
            <button id="gallery-prev" class="text-white transition" aria-label="Imagen anterior">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </button>
            <span id="gallery-counter" class="font-poppins text-white/70 text-sm"></span>
            <button id="gallery-next" class="text-white transition" aria-label="Imagen siguiente">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </button>
        </div>
    </div>
</div>

<script>
    const isDesktop = () => window.matchMedia('(min-width: 768px)').matches;

    // Accordion logic
    const items = document.querySelectorAll('.accordion-item');

    function loadDesktopGallery(galleryData: string[]) {
        const dTrack = document.getElementById('desktop-gallery-track') as HTMLElement;
        const dotsContainer = document.getElementById('desktop-gallery-dots') as HTMLElement;

        let dCurrent = 0;
        const dTotal = galleryData.length;

        dTrack.innerHTML = '';
        galleryData.forEach((src) => {
            const slide = document.createElement('div');
            slide.className = 'w-full h-full shrink-0 flex items-center justify-center';
            const img = document.createElement('img');
            img.src = src;
            img.alt = '';
            img.className = 'h-full w-full object-contain   ';
            img.loading = 'lazy';
            slide.appendChild(img);
            dTrack.appendChild(slide);
        });

        function updateDesktop() {
            dTrack.style.transform = `translateX(-${dCurrent * 100}%)`;
            dotsContainer.querySelectorAll('.svc-dot').forEach((dot, i) => {
                const el = dot as HTMLElement;
                if (i === dCurrent) {
                    el.classList.add('w-5', 'bg-[#EB192E]');
                    el.classList.remove('w-2.5', 'bg-white/30');
                } else {
                    el.classList.remove('w-5', 'bg-[#EB192E]');
                    el.classList.add('w-2.5', 'bg-white/30');
                }
            });
        }

        dotsContainer.innerHTML = '';
        galleryData.forEach((_, i) => {
            const dot = document.createElement('button');
            dot.className = `svc-dot rounded-full h-2.5 transition-all duration-300 ${i === 0 ? 'w-5 bg-[#EB192E]' : 'w-2.5 bg-white/30'}`;
            dot.setAttribute('aria-label', `Imagen ${i + 1}`);
            dot.addEventListener('click', () => { dCurrent = i; updateDesktop(); });
            dotsContainer.appendChild(dot);
        });

        updateDesktop();

        // Touch swipe
        let touchStartX = 0;
        dTrack.addEventListener('touchstart', (e) => {
            touchStartX = e.touches[0].clientX;
        }, { passive: true });
        dTrack.addEventListener('touchend', (e) => {
            const diff = touchStartX - e.changedTouches[0].clientX;
            if (Math.abs(diff) > 50) {
                if (diff > 0 && dCurrent < dTotal - 1) { dCurrent++; updateDesktop(); }
                else if (diff < 0 && dCurrent > 0) { dCurrent--; updateDesktop(); }
            }
        }, { passive: true });

        // Mouse drag
        let mouseStartX = 0;
        let isDragging = false;
        dTrack.addEventListener('mousedown', (e) => {
            isDragging = true;
            mouseStartX = e.clientX;
            dTrack.style.cursor = 'grabbing';
        });
        document.addEventListener('mouseup', (e) => {
            if (!isDragging) return;
            isDragging = false;
            dTrack.style.cursor = 'grab';
            const diff = mouseStartX - e.clientX;
            if (Math.abs(diff) > 50) {
                if (diff > 0 && dCurrent < dTotal - 1) { dCurrent++; updateDesktop(); }
                else if (diff < 0 && dCurrent > 0) { dCurrent--; updateDesktop(); }
            }
        });
    }

    items.forEach((item) => {
        const header = item.querySelector('.accordion-header') as HTMLButtonElement;
        const content = item.querySelector('.accordion-content') as HTMLElement;
        const icon = item.querySelector('.accordion-icon') as HTMLElement;

        header.addEventListener('click', () => {
            const isOpen = header.getAttribute('aria-expanded') === 'true';

            // Close all others with animation
            items.forEach((otherItem) => {
                if (otherItem === item) return;
                const otherHeader = otherItem.querySelector('.accordion-header') as HTMLButtonElement;
                const otherContent = otherItem.querySelector('.accordion-content') as HTMLElement;
                const otherIcon = otherItem.querySelector('.accordion-icon') as HTMLElement;
                otherHeader.setAttribute('aria-expanded', 'false');
                otherContent.classList.remove('max-h-60');
                otherContent.classList.add('max-h-0');
                otherIcon.textContent = '+';
            });

            if (!isOpen) {
                content.classList.remove('max-h-0');
                content.classList.add('max-h-60');
                header.setAttribute('aria-expanded', 'true');
                icon.textContent = '−';

                // On desktop, update the right-side gallery
                if (isDesktop()) {
                    const gallery = JSON.parse((item as HTMLElement).dataset.gallery || '[]');
                    loadDesktopGallery(gallery);
                }
            } else {
                // Close the current item
                content.classList.remove('max-h-60');
                content.classList.add('max-h-0');
                header.setAttribute('aria-expanded', 'false');
                icon.textContent = '+';
            }
        });
    });

    // Load first service gallery on desktop
    if (isDesktop()) {
        const firstItem = items[0] as HTMLElement;
        const gallery = JSON.parse(firstItem.dataset.gallery || '[]');
        loadDesktopGallery(gallery);
    }

    // Gallery modal logic (mobile only)
    const modal = document.getElementById('gallery-modal') as HTMLElement;
    const modalTitle = document.getElementById('gallery-title') as HTMLElement;
    const track = document.getElementById('gallery-track') as HTMLElement;
    const counter = document.getElementById('gallery-counter') as HTMLElement;
    const closeBtn = document.getElementById('gallery-close') as HTMLButtonElement;
    const overlay = document.getElementById('gallery-overlay') as HTMLElement;
    const prevBtn = document.getElementById('gallery-prev') as HTMLButtonElement;
    const nextBtn = document.getElementById('gallery-next') as HTMLButtonElement;

    let currentImg = 0;
    let totalImgs = 0;

    function openGallery(title: string, images: string[]) {
        modalTitle.textContent = title;
        currentImg = 0;
        totalImgs = images.length;

        track.innerHTML = '';
        images.forEach((src) => {
            const slide = document.createElement('div');
            slide.className = 'w-full shrink-0 flex items-center justify-center px-4';
            const img = document.createElement('img');
            img.src = src;
            img.alt = title;
            img.className = 'max-h-full max-w-full object-contain rounded-lg';
            img.loading = 'lazy';
            slide.appendChild(img);
            track.appendChild(slide);
        });

        updateGallery();
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        document.body.style.overflow = 'hidden';
    }

    function closeGallery() {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
        document.body.style.overflow = '';
        track.innerHTML = '';
    }

    function updateGallery() {
        track.style.transform = `translateX(-${currentImg * 100}%)`;
        counter.textContent = `${currentImg + 1} / ${totalImgs}`;
        prevBtn.style.opacity = currentImg === 0 ? '0.2' : '1';
        nextBtn.style.opacity = currentImg >= totalImgs - 1 ? '0.2' : '1';
    }

    document.querySelectorAll('.gallery-btn').forEach((btn) => {
        btn.addEventListener('click', (e) => {
            e.preventDefault();
            if (isDesktop()) return; // On desktop, gallery is in the right column
            const accordionItem = (btn as HTMLElement).closest('.accordion-item') as HTMLElement;
            const gallery = JSON.parse(accordionItem.dataset.gallery || '[]');
            const title = (btn as HTMLElement).dataset.title || '';
            openGallery(title, gallery);
        });
    });

    closeBtn.addEventListener('click', closeGallery);
    overlay.addEventListener('click', closeGallery);

    prevBtn.addEventListener('click', () => {
        if (currentImg > 0) { currentImg--; updateGallery(); }
    });

    nextBtn.addEventListener('click', () => {
        if (currentImg < totalImgs - 1) { currentImg++; updateGallery(); }
    });

    let startX = 0;
    track.addEventListener('touchstart', (e) => {
        startX = e.touches[0].clientX;
    }, { passive: true });

    track.addEventListener('touchend', (e) => {
        const diff = startX - e.changedTouches[0].clientX;
        if (Math.abs(diff) > 50) {
            if (diff > 0 && currentImg < totalImgs - 1) { currentImg++; updateGallery(); }
            else if (diff < 0 && currentImg > 0) { currentImg--; updateGallery(); }
        }
    }, { passive: true });

    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !modal.classList.contains('hidden')) closeGallery();
        if (e.key === 'ArrowLeft' && !modal.classList.contains('hidden') && currentImg > 0) { currentImg--; updateGallery(); }
        if (e.key === 'ArrowRight' && !modal.classList.contains('hidden') && currentImg < totalImgs - 1) { currentImg++; updateGallery(); }
    });
</script>