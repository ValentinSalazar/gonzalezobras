---
import TitleSection from "../TitleSection.astro";
import ButtonRed from "../ButtonRed.astro";
import antes01 from "../../assets/antes01.webp";
import antes02 from "../../assets/antes02.webp";
import antes03 from "../../assets/antes03.webp";
import antes04 from "../../assets/antes04.webp";
import antes05 from "../../assets/antes05.webp";
import despues01 from "../../assets/despues01.webp";
import despues02 from "../../assets/despues02.webp";
import despues03 from "../../assets/despues03.webp";
import despues04 from "../../assets/despues04.webp";
import despues05 from "../../assets/despues05.webp";

const transformaciones = [
    { before: antes02, after: despues02 },
    { before: antes01, after: despues01 },
    { before: antes03, after: despues03 },
    { before: antes04, after: despues04 },
    { before: antes05, after: despues05 },
];

const srcs = transformaciones.map(t => ({ before: t.before.src, after: t.after.src }));
---

<section class="w-screen pb-10 relative">
    <TitleSection title="Transformaciones" color="first" subtitle="antes y después" new_clases="pl-5 md:pl-20 xl:pl-40 pb-5"/>

    <div class="w-full mt-4 px-5 md:px-16 xl:px-40">
        <!-- Comparison slider -->
        <div
            id="comp-slider"
            class="relative overflow-hidden select-none cursor-ew-resize"
            style="height: 60vw; max-height: 72vh;"
        >
            <!-- Before image -->
            <img id="comp-before" class="absolute inset-0 w-full h-full object-cover" alt="Antes" />

            <!-- After image clipped -->
            <div id="comp-after-wrap" class="absolute inset-0 overflow-hidden" style="width:50%">
                <img id="comp-after" class="absolute top-0 left-0 h-full object-cover" alt="Después" />
            </div>

            <!-- Edge gradients -->
            <div class="absolute inset-0 pointer-events-none z-10" style="background: linear-gradient(to bottom, rgba(0,0,0,0.35) 0%, transparent 18%, transparent 82%, rgba(0,0,0,0.35) 100%)"></div>

            <!-- Labels -->
            <span class="absolute bottom-4 left-5 z-20 font-bebas text-white/75 text-lg md:text-3xl tracking-widest pointer-events-none">ANTES</span>
            <span class="absolute bottom-4 right-5 z-20 font-bebas text-white/75 text-lg md:text-3xl tracking-widest pointer-events-none">DESPUÉS</span>

            <!-- Handle -->
            <div id="comp-handle" class="absolute top-0 bottom-0 z-30 flex flex-col items-center" style="left:50%; transform:translateX(-50%)">
                <div class="w-px flex-1 bg-white/80"></div>
                <div class="w-9 h-9 md:w-11 md:h-11 shrink-0 bg-white rounded-full flex items-center justify-center shadow-lg cursor-ew-resize handle-pulse">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                        <path d="M8 5L3 12L8 19M16 5L21 12L16 19" stroke="#EB192E" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </div>
                <div class="w-px flex-1 bg-white/80"></div>
            </div>

            <!-- Hint -->
            <div id="comp-hint" class="absolute inset-0 z-40 flex items-center justify-center pointer-events-none">
                <span class="font-poppins text-white/90 text-xs md:text-sm tracking-widest bg-black/40 px-4 py-2 rounded-full hint-fade">← deslizá →</span>
            </div>
        </div>

        <!-- Dots + button in same row -->
        <div class="flex items-center justify-between mt-5">
            <div class="flex gap-3">
                {transformaciones.map((_, i) => (
                    <button
                        class={`comp-dot rounded-full transition-all duration-300 ${i === 0 ? 'w-5 h-2.5 bg-first' : 'w-2.5 h-2.5 bg-black/25 hover:bg-black/40'}`}
                        data-index={i}
                        aria-label={`Transformación ${i + 1}`}
                    ></button>
                ))}
            </div>
            <ButtonRed href="/transformaciones" text="VER MAS TRANSFORMACIONES" size="sm" mdSize="lg" icon color="secondary" />
        </div>
    </div>
</section>

<style>
    .hint-fade {
        animation: hintFade 2.5s ease forwards;
        animation-delay: 0.8s;
        opacity: 0;
    }
    @keyframes hintFade {
        0%   { opacity: 0; transform: translateY(4px); }
        20%  { opacity: 1; transform: translateY(0); }
        75%  { opacity: 1; }
        100% { opacity: 0; }
    }
    .handle-pulse {
        animation: handlePulse 1.8s ease-in-out 3;
    }
    @keyframes handlePulse {
        0%, 100% { box-shadow: 0 0 0 0 rgba(255,255,255,0.5); }
        50%       { box-shadow: 0 0 0 8px rgba(255,255,255,0); }
    }
</style>

<script define:vars={{ srcs }}>
    const slider = document.getElementById('comp-slider');
    const beforeImg = document.getElementById('comp-before');
    const afterWrap = document.getElementById('comp-after-wrap');
    const afterImg = document.getElementById('comp-after');
    const handle = document.getElementById('comp-handle');
    const dots = document.querySelectorAll('.comp-dot');

    let currentIndex = 0;
    let isDragging = false;
    let pos = 50;

    function setAfterWidth() {
        afterImg.style.width = slider.offsetWidth + 'px';
    }

    function updateHandle() {
        const clamped = Math.min(Math.max(pos, 3), 97);
        afterWrap.style.width = clamped + '%';
        handle.style.left = clamped + '%';
    }

    function getPercent(e) {
        const rect = slider.getBoundingClientRect();
        const clientX = e.touches ? e.touches[0].clientX : e.clientX;
        return ((clientX - rect.left) / rect.width) * 100;
    }

    function loadSlide(index) {
        beforeImg.src = srcs[index].before;
        afterImg.src = srcs[index].after;
        pos = 50;
        setAfterWidth();
        updateHandle();

        dots.forEach((dot, i) => {
            if (i === index) {
                dot.classList.add('w-5', 'bg-first');
                dot.classList.remove('w-2.5', 'bg-black/25');
            } else {
                dot.classList.remove('w-5', 'bg-first');
                dot.classList.add('w-2.5', 'bg-black/25');
            }
        });
        currentIndex = index;
    }

    slider.addEventListener('mousedown', (e) => { isDragging = true; pos = getPercent(e); updateHandle(); });
    document.addEventListener('mousemove', (e) => { if (isDragging) { pos = getPercent(e); updateHandle(); } });
    document.addEventListener('mouseup', () => { isDragging = false; });

    slider.addEventListener('touchstart', (e) => { isDragging = true; pos = getPercent(e); updateHandle(); }, { passive: true });
    slider.addEventListener('touchmove', (e) => { if (isDragging) { pos = getPercent(e); updateHandle(); } }, { passive: true });
    slider.addEventListener('touchend', () => { isDragging = false; });

    dots.forEach((dot, i) => dot.addEventListener('click', () => loadSlide(i)));

    window.addEventListener('resize', () => { setAfterWidth(); updateHandle(); });

    loadSlide(0);
</script>
