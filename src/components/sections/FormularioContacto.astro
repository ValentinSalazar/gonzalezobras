---
---

<section class="bg-white px-5 md:px-14 xl:px-16 py-14 flex flex-col justify-center">
    <span class="flex w-14 h-1 bg-first mb-4"></span>
    <h2 class="font-bebas text-gray-900 text-4xl leading-none mb-1">Escribinos</h2>
    <p class="font-poppins text-gray-400 text-sm mb-8">Te respondemos en menos de 24 horas.</p>

    <form id="contact-form" class="flex flex-col gap-5" novalidate>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
                <label class="font-poppins font-medium text-xs uppercase tracking-widest text-gray-400 block mb-2" for="nombre">Nombre</label>
                <input
                    type="text"
                    id="nombre"
                    name="name"
                    placeholder="Tu nombre"
                    class="w-full border border-gray-200 px-4 py-3 font-poppins text-sm text-gray-700 outline-none focus:border-first transition bg-gray-50"
                    required
                />
                <p class="form-error font-poppins text-first text-xs mt-1 hidden"></p>
            </div>
            <div>
                <label class="font-poppins font-medium text-xs uppercase tracking-widest text-gray-400 block mb-2" for="email">Email</label>
                <input
                    type="email"
                    id="email"
                    name="email"
                    placeholder="tu@email.com"
                    class="w-full border border-gray-200 px-4 py-3 font-poppins text-sm text-gray-700 outline-none focus:border-first transition bg-gray-50"
                    required
                />
                <p class="form-error font-poppins text-first text-xs mt-1 hidden"></p>
            </div>
        </div>
        <div>
            <label class="font-poppins font-medium text-xs uppercase tracking-widest text-gray-400 block mb-2" for="servicio">Servicio de interés</label>
            <select
                id="servicio"
                name="servicio"
                class="w-full border border-gray-200 px-4 py-3 font-poppins text-sm text-gray-500 outline-none focus:border-first transition bg-gray-50 appearance-none"
            >
                <option value="">Seleccioná un servicio</option>
                <option>Wall Panel</option>
                <option>PVC</option>
                <option>Cielorrasos</option>
                <option>Amoblamientos</option>
                <option>Revestimientos</option>
                <option>Steel Frame</option>
                <option>Otro</option>
            </select>
        </div>
        <div>
            <label class="font-poppins font-medium text-xs uppercase tracking-widest text-gray-400 block mb-2" for="mensaje">Mensaje</label>
            <textarea
                id="mensaje"
                name="message"
                rows="5"
                placeholder="Contanos sobre tu proyecto..."
                class="w-full border border-gray-200 px-4 py-3 font-poppins text-sm text-gray-700 outline-none focus:border-first transition resize-none bg-gray-50"
                required
            ></textarea>
            <p class="form-error font-poppins text-first text-xs mt-1 hidden"></p>
        </div>
        <button
            type="submit"
            id="submit-btn"
            class="font-bebas bg-first text-white text-xl tracking-wider py-3 hover:bg-red-700 transition disabled:opacity-50 flex items-center justify-center gap-2"
        >
            ENVIAR MENSAJE
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </button>
        <p id="form-status" class="font-poppins text-sm text-center hidden"></p>
    </form>
</section>

<script>
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const formStatus = document.getElementById('form-status') as HTMLElement;

    const validators: Record<string, (value: string) => string> = {
        name: (v) => v.trim() === '' ? 'El nombre es obligatorio' : '',
        email: (v) => {
            if (v.trim() === '') return 'El email es obligatorio';
            if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v)) return 'Ingresá un email válido';
            return '';
        },
        message: (v) => v.trim() === '' ? 'El mensaje es obligatorio' : '',
    };

    function showError(field: HTMLInputElement | HTMLTextAreaElement, message: string) {
        field.classList.remove('border-gray-200');
        field.classList.add('border-first');
        const errorEl = field.parentElement?.querySelector('.form-error') as HTMLElement;
        if (errorEl) {
            errorEl.textContent = message;
            errorEl.classList.remove('hidden');
        }
    }

    function clearError(field: HTMLInputElement | HTMLTextAreaElement) {
        field.classList.remove('border-first');
        field.classList.add('border-gray-200');
        const errorEl = field.parentElement?.querySelector('.form-error') as HTMLElement;
        if (errorEl) {
            errorEl.textContent = '';
            errorEl.classList.add('hidden');
        }
    }

    ['name', 'email', 'message'].forEach((name) => {
        const field = form.elements.namedItem(name) as HTMLInputElement | HTMLTextAreaElement;
        field.addEventListener('input', () => clearError(field));
    });

    form.addEventListener('submit', async (e) => {
        e.preventDefault();
        formStatus.classList.add('hidden');

        let hasErrors = false;

        for (const [name, validate] of Object.entries(validators)) {
            const field = form.elements.namedItem(name) as HTMLInputElement | HTMLTextAreaElement;
            const error = validate(field.value);
            if (error) {
                showError(field, error);
                hasErrors = true;
            } else {
                clearError(field);
            }
        }

        if (hasErrors) return;

        submitBtn.disabled = true;
        submitBtn.textContent = 'ENVIANDO...';

        try {
            const servicioField = form.elements.namedItem('servicio') as HTMLSelectElement;
            const res = await fetch('https://api.web3forms.com/submit', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Accept': 'application/json',
                },
                body: JSON.stringify({
                    access_key: 'f25a7dd1-ce4d-4aaa-9015-1e6775233432',
                    subject: 'Nuevo mensaje desde González Obras',
                    from_name: 'Gonzalez Obras – Consultas',
                    name: (form.elements.namedItem('name') as HTMLInputElement).value,
                    email: (form.elements.namedItem('email') as HTMLInputElement).value,
                    servicio: servicioField?.value || 'No especificado',
                    message: (form.elements.namedItem('message') as HTMLTextAreaElement).value,
                }),
            });

            const data = await res.json();

            if (data.success) {
                formStatus.textContent = '¡Mensaje enviado correctamente!';
                formStatus.className = 'font-poppins text-sm text-center text-green-600';
                form.reset();
            } else {
                formStatus.textContent = `Error: ${data.message || 'Intentá de nuevo.'}`;
                formStatus.className = 'font-poppins text-sm text-center text-first';
            }
        } catch {
            formStatus.textContent = 'Error de conexión. Intentá de nuevo.';
            formStatus.className = 'font-poppins text-sm text-center text-first';
        } finally {
            submitBtn.disabled = false;
            submitBtn.textContent = 'ENVIAR MENSAJE';
        }
    });
</script>
