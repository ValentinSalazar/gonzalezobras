---
import TitleSection from "../TitleSection.astro";
---

<section class="relative w-full px-5 py-5 md:w-1/2">
    <span class="flex w-20 h-1.25 bg-first mb-2 mt-2 sm:mt-5 md:mt-0"></span>
    <TitleSection
        title="Contactanos"
        color="black"
        subtitle="despejá tus dudas"
        mas_color="first"
    />
    <form id="contact-form" class="my-5 flex flex-col gap-5" novalidate>
        <div>
            <label class="font-poppins font-medium text-sm block mb-2" for="nombre">Nombre</label>
            <input
                type="text"
                id="nombre"
                name="name"
                placeholder="Braulio"
                class="w-full border border-black/40 px-4 py-3 font-poppins text-sm text-black/50 outline-none focus:border-first transition"
                required
            />
            <p class="form-error font-poppins text-first text-xs mt-1 hidden"></p>
        </div>
        <div>
            <label class="font-poppins font-medium text-sm block mb-2" for="email">Email</label>
            <input
                type="email"
                id="email"
                name="email"
                placeholder="Braulio@hotmail.com"
                class="w-full border border-black/40 px-4 py-3 font-poppins text-sm text-black/50 outline-none focus:border-first transition"
                required
            />
            <p class="form-error font-poppins text-first text-xs mt-1 hidden"></p>
        </div>
        <div>
            <label class="font-poppins font-medium text-sm block mb-2" for="mensaje">Mensaje</label>
            <textarea
                id="mensaje"
                name="message"
                rows="6"
                placeholder="Hola me comunico para consultar.."
                class="w-full border border-black/40 px-4 py-3 font-poppins text-sm text-black/50 outline-none focus:border-first transition resize-none"
                required
            ></textarea>
            <p class="form-error font-poppins text-first text-xs mt-1 hidden"></p>
        </div>
        <button
            type="submit"
            id="submit-btn"
            class="font-bebas bg-first text-white text-xl tracking-wider py-1 hover:bg-red-700 transition disabled:opacity-50"
        >
            ENVIAR
        </button>
        <p id="form-status" class="font-poppins text-sm text-center hidden"></p>
    </form>
</section>

<script>
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const formStatus = document.getElementById('form-status') as HTMLElement;

    const validators: Record<string, (value: string) => string> = {
        name: (v) => v.trim() === '' ? 'El nombre es obligatorio' : '',
        email: (v) => {
            if (v.trim() === '') return 'El email es obligatorio';
            if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v)) return 'Ingresá un email válido';
            return '';
        },
        message: (v) => v.trim() === '' ? 'El mensaje es obligatorio' : '',
    };

    function showError(field: HTMLInputElement | HTMLTextAreaElement, message: string) {
        field.classList.remove('border-black/40');
        field.classList.add('border-first');
        const errorEl = field.parentElement?.querySelector('.form-error') as HTMLElement;
        if (errorEl) {
            errorEl.textContent = message;
            errorEl.classList.remove('hidden');
        }
    }

    function clearError(field: HTMLInputElement | HTMLTextAreaElement) {
        field.classList.remove('border-first');
        field.classList.add('border-black/40');
        const errorEl = field.parentElement?.querySelector('.form-error') as HTMLElement;
        if (errorEl) {
            errorEl.textContent = '';
            errorEl.classList.add('hidden');
        }
    }

    // Clear error on input
    ['name', 'email', 'message'].forEach((name) => {
        const field = form.elements.namedItem(name) as HTMLInputElement | HTMLTextAreaElement;
        field.addEventListener('input', () => clearError(field));
    });

    form.addEventListener('submit', async (e) => {
        e.preventDefault();
        formStatus.classList.add('hidden');

        let hasErrors = false;

        for (const [name, validate] of Object.entries(validators)) {
            const field = form.elements.namedItem(name) as HTMLInputElement | HTMLTextAreaElement;
            const error = validate(field.value);
            if (error) {
                showError(field, error);
                hasErrors = true;
            } else {
                clearError(field);
            }
        }

        if (hasErrors) return;

        submitBtn.disabled = true;
        submitBtn.textContent = 'ENVIANDO...';

        try {
            const res = await fetch('https://api.web3forms.com/submit', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Accept': 'application/json',
                },
                body: JSON.stringify({
                    access_key: 'f25a7dd1-ce4d-4aaa-9015-1e6775233432',
                    subject: 'Nuevo mensaje desde González Obras',
                    from_name: 'Gonzalez Obras – Consultas',
                    name: (form.elements.namedItem('name') as HTMLInputElement).value,
                    email: (form.elements.namedItem('email') as HTMLInputElement).value,
                    message: (form.elements.namedItem('message') as HTMLTextAreaElement).value,
                }),
            });

            const data = await res.json();

            if (data.success) {
                formStatus.textContent = '¡Mensaje enviado correctamente!';
                formStatus.className = 'font-poppins text-sm text-center text-green-600';
                form.reset();
            } else {
                formStatus.textContent = `Error: ${data.message || 'Intentá de nuevo.'}`;
                formStatus.className = 'font-poppins text-sm text-center text-first';
            }
        } catch {
            formStatus.textContent = 'Error de conexión. Intentá de nuevo.';
            formStatus.className = 'font-poppins text-sm text-center text-first';
        } finally {
            submitBtn.disabled = false;
            submitBtn.textContent = 'ENVIAR';
        }
    });
</script>