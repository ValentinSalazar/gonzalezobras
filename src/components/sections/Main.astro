---
import ScrollDown from "../icons/ScrollDown.astro";
import heroMobile from "../../assets/HeroMobile.webp";
import heroDesktop from "../../assets/hero.webp";
import ButtonRed from "../ButtonRed.astro";
import proj1 from "../../assets/projects/proyectos01.webp";
import proj2 from "../../assets/projects/proyectos02.webp";
import proj3 from "../../assets/projects/proyectos03.webp";
---

<div class="relative overflow-hidden bg-black">
<picture class="absolute left-0 w-full h-full pointer-events-none select-none lg:object-bottom">
	<source
		media="(min-width: 1024px)"
		srcset={heroDesktop.src}
		width={heroDesktop.width}
		height={heroDesktop.height}
	/>
	<img
		src={heroMobile.src}
		alt="González Obras - Construcción en Seco en San Pedro, Buenos Aires"
		width={heroMobile.width}
		height={heroMobile.height}
		class="w-full h-full object-cover object-center"
		loading="eager"
		fetchpriority="high"
		decoding="async"
	/>
</picture>

<main class="relative z-10">
	<div class="hero-gradient absolute inset-0"></div>

	<section class="relative z-10 flex flex-col items-center lg:flex-row lg:items-stretch h-[100svh] pt-28 pb-6 px-10 lg:pt-0 lg:pb-0 lg:px-0">
		<div class="flex-1 flex flex-col items-center justify-center lg:flex-none lg:w-[42%] lg:items-start lg:justify-center lg:pl-16 xl:pl-40 lg:pt-28 lg:pb-6">
			<h1 class="font-bebas leading-none text-center lg:text-left">
				<span class="block text-[13vw] md:text-[10vw] xl:text-[85px] text-first">CONSTRUCCIÓN</span>
				<span class="block text-[25vw] md:text-[18.5vw] xl:text-[160px] text-secondary -mt-2">EN SECO</span>
			</h1>
			<p
				class="font-poppins text-secondary sm:mt-4 max-w-[85vw] w-full text-center lg:text-left md:text-xl lg:text-pretty lg:text-xl lg:mt-0"
			>
				Transformamos tus espacios con un <span><br/></span>sistema rápido, limpio y
				a medida.
			</p>
			<div class="w-full max-w-[75vw] flex gap-5 pt-5 lg:max-w-100">
				<a
					href="/proyectos"
					class="font-bebas text-secondary border border-secondary px-6 py-1 tracking-wider hover:bg-secondary hover:text-black transition w-[50%] text-lg md:text-xl flex items-center justify-center"
				>
					PROYECTOS
				</a>
				<ButtonRed href="https://wa.me/3329335202?text=Hola%2C%20quiero%20consultar%20por%20un%20presupuesto" text="PRESUPUESTOS" size="lg" mdSize="lg" color="secondary" target="_blank" class="w-[50%] justify-center" />
			</div>
			<div class="max-w-[75vw] lg:max-w-full w-full lg:mt-5">
				<span class="flex w-20 h-1.25 bg-first mb-2 mt-3 sm:mt-5 lg:mb-5"></span>
				<p
					class="font-bebas text-secondary z-50 text-left w-full text-[8vw] md:text-5xl leading-tight lg:text-4xl"
				>
					Más <span class="text-first">de 8 años</span> en el <br />rubro y <span class="text-first">150 obras</span> finalizadas
				</p>
			</div>
		</div>

		<!-- Columna derecha: filmstrip (solo desktop) -->
		<div class="hidden lg:flex lg:flex-1 lg:items-center lg:justify-center relative z-50">
			<div class="filmstrip-wrapper flex gap-2 w-[52%] h-[60%] overflow-hidden">
				<div class="flex-1 overflow-hidden">
					<div class="filmstrip-up flex flex-col gap-2">
						{[proj1, proj2, proj3, proj1, proj2, proj3].map((img) => (
							<a href="/proyectos" class="block overflow-hidden flex-shrink-0 aspect-[3/4]">
								<img src={img.src} alt="Proyecto González Obras" width={img.width} height={img.height} class="w-full h-full object-cover object-center hover:scale-105 transition-transform duration-500" loading="eager" decoding="async" />
							</a>
						))}
					</div>
				</div>
				<div class="flex-1 overflow-hidden">
					<div class="filmstrip-down flex flex-col gap-2">
						{[proj3, proj1, proj2, proj3, proj1, proj2].map((img) => (
							<a href="/proyectos" class="block overflow-hidden flex-shrink-0 aspect-[3/4]">
								<img src={img.src} alt="Proyecto González Obras" width={img.width} height={img.height} class="w-full h-full object-cover object-center hover:scale-105 transition-transform duration-500" loading="eager" decoding="async" />
							</a>
						))}
					</div>
				</div>
			</div>
		</div>

		<div class="mb-10 lg:absolute lg:bottom-6 lg:left-[21%] lg:-translate-x-1/2"><ScrollDown /></div>
	</section>
</main>
</div>

<style>
	.hero-gradient {
		background: linear-gradient(to bottom, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.7) 75%, rgba(0,0,0,0) 100%);
	}

	@media (min-width: 1024px) {
		.hero-gradient {
			background: linear-gradient(to bottom, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.7) 75%, rgba(0,0,0,0) 100%);
		}
	}

	.filmstrip-wrapper {
		-webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 10%, black 90%, transparent 100%);
		mask-image: linear-gradient(to bottom, transparent 0%, black 10%, black 90%, transparent 100%);
	}

	.filmstrip-up {
		animation: scroll-up 28s linear infinite;
	}
	.filmstrip-down {
		animation: scroll-down 28s linear infinite;
	}
	.filmstrip-wrapper:hover .filmstrip-up,
	.filmstrip-wrapper:hover .filmstrip-down {
		animation-play-state: paused;
	}

	@keyframes scroll-up {
		from { transform: translateY(0); }
		to   { transform: translateY(-50%); }
	}
	@keyframes scroll-down {
		from { transform: translateY(-50%); }
		to   { transform: translateY(0); }
	}
</style>
