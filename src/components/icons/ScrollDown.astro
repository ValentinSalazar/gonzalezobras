<div class="flex flex-col items-center -space-y-1">
  <svg class="chevron chevron-1" width="20" height="12" viewBox="0 0 28 16" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M2 2L14 14L26 2" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
  <svg class="chevron chevron-2" width="20" height="12" viewBox="0 0 28 16" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M2 2L14 14L26 2" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
  <svg class="chevron chevron-3" width="20" height="12" viewBox="0 0 28 16" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M2 2L14 14L26 2" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
</div>

<style>
  .chevron {
    opacity: 0;
    animation: light-up 2s ease-in-out infinite;
  }

  .chevron-1 {
    animation-delay: 0s;
  }

  .chevron-2 {
    animation-delay: 0.3s;
  }

  .chevron-3 {
    animation-delay: 0.6s;
  }

  @keyframes light-up {
    0% {
      opacity: 0;
    }
    30% {
      opacity: 1;
    }
    60%, 100% {
      opacity: 0;
    }
  }
</style>
