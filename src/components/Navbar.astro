---
import Menu from "./icons/Menu.astro";
import Instagram from "./icons/Instagram.astro";
import Facebook from "./icons/Facebook.astro";
import ButtonRed from "./ButtonRed.astro";
---

<nav class="flex justify-between items-center px-5 md:px-20 font-poppins absolute pt-10 z-50 w-full" aria-label="Navegación principal">
    <a href="/" class="text-white">Gonzalez</a>
    <button id="menu-open" aria-label="Abrir menú" class="bg-transparent border-none cursor-pointer p-0">
        <Menu color="#ffffff" class="w-8 h-8"/>
    </button>
</nav>

<div
    id="menu-overlay"
    class="fixed inset-0 z-[60] bg-black/60 opacity-0 pointer-events-none transition-opacity duration-300"
    aria-hidden="true"
></div>

<div
    id="menu-drawer"
    class="fixed top-0 right-0 z-[70] h-full w-[65%] md:w-[45%] bg-black translate-x-full transition-transform duration-300 flex flex-col px-8 md:px-14 py-10 md:py-16"
    aria-hidden="true"
    role="dialog"
    aria-modal="true"
    aria-label="Menú de navegación"
>
    <button id="menu-close" aria-label="Cerrar menú" class="self-end bg-transparent border-none cursor-pointer p-0 text-white mb-10">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 md:w-12 md:h-12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
    </button>

    <ul class="flex flex-col gap-2 md:gap-5 font-poppins text-white text-lg md:text-3xl">
        <li><a href="/" class="hover:text-first transition-colors">Inicio</a></li>
        <li><a href="/proyectos" class="hover:text-first transition-colors">Proyectos</a></li>
        <li><a href="/servicios" class="hover:text-first transition-colors">Servicios</a></li>
        <li><a href="/transformaciones" class="hover:text-first transition-colors">Transformaciones</a></li>
        <li><a href="/contacto" class="hover:text-first transition-colors">Contacto</a></li>
    </ul>

    <div class="mt-auto flex flex-col gap-4">
        <div>
            <p class="font-bebas text-white/50 text-sm tracking-widest mb-3">Seguinos</p>
            <div class="flex gap-4 items-center">
                <a href="https://instagram.com/GonzalezObras" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
                    <Instagram fill="white" stroke="black" />
                </a>
                <a href="https://facebook.com/FacundoGonzalez" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
                    <Facebook color="white" />
                </a>
            </div>
        </div>
        <ButtonRed href="https://wa.me/3329335202?text=Hola%2C%20quiero%20consultar%20por%20un%20presupuesto" text="PRESUPUESTO" size="md" target="_blank" class="justify-center" />
    </div>
</div>

<script>
    function initMenu() {
        const openBtn = document.getElementById('menu-open')!;
        const closeBtn = document.getElementById('menu-close')!;
        const overlay = document.getElementById('menu-overlay')!;
        const drawer = document.getElementById('menu-drawer')!;
        const navLinks = drawer.querySelectorAll('a');

        function openMenu() {
            drawer.classList.remove('translate-x-full');
            overlay.classList.remove('opacity-0', 'pointer-events-none');
            drawer.setAttribute('aria-hidden', 'false');
            overlay.setAttribute('aria-hidden', 'false');
            document.body.style.overflow = 'hidden';
        }

        function closeMenu() {
            drawer.classList.add('translate-x-full');
            overlay.classList.add('opacity-0', 'pointer-events-none');
            drawer.setAttribute('aria-hidden', 'true');
            overlay.setAttribute('aria-hidden', 'true');
            document.body.style.overflow = '';
        }

        openBtn.addEventListener('click', openMenu);
        closeBtn.addEventListener('click', closeMenu);
        overlay.addEventListener('click', closeMenu);
        navLinks.forEach(link => link.addEventListener('click', closeMenu));
    }

    document.addEventListener('astro:page-load', initMenu);
</script>
