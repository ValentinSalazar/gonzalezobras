---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import ButtonRed from '../components/ButtonRed.astro';
import Footer from '../components/sections/Footer.astro';
import { Image } from 'astro:assets';
import antes01 from '../assets/antes01.webp';
import antes02 from '../assets/antes02.webp';
import antes03 from '../assets/antes03.webp';
import antes04 from '../assets/antes04.webp';
import antes05 from '../assets/antes05.webp';
import despues01 from '../assets/despues01.webp';
import despues02 from '../assets/despues02.webp';
import despues03 from '../assets/despues03.webp';
import despues04 from '../assets/despues04.webp';
import despues05 from '../assets/despues05.webp';
import hero from '../assets/transformacionesHero.webp';

const transformaciones = [
    { number: "01", title: "Cielorrasos y terminaciones", category: "Cielorrasos", before: antes02, after: despues02 },
    { number: "02", title: "Revestimiento interior", category: "Revestimientos", before: antes01, after: despues01 },
    { number: "03", title: "Reforma completa", category: "Reformas", before: antes03, after: despues03 },
    { number: "04", title: "Construcción en seco", category: "Construcción en Seco", before: antes04, after: despues04 },
    { number: "05", title: "Amoblamientos a medida", category: "Amoblamientos", before: antes05, after: despues05 },
];

const allCategories = ["Todos", ...new Set(transformaciones.map(t => t.category))];
---

<Layout
    title="Transformaciones Antes y Después | González Obras - San Pedro, Buenos Aires"
    description="Mirá las transformaciones reales de nuestras obras de construcción en seco. Cielorrasos, revestimientos, reformas completas y amoblamientos a medida en San Pedro, Buenos Aires."
>
    <Navbar />

    <div class="relative h-80 overflow-hidden">
        <Image
            src={hero}
            alt="Transformaciones González Obras"
            width={800}
            class="absolute inset-0 w-full h-full object-cover"
            loading="eager"
            fetchpriority="high"
        />
        <div class="absolute inset-0 bg-gradient-to-b from-black via-black/90 to-black/60"></div>
        <div class="absolute top-32 left-0 right-0 z-10 px-5 md:px-20 xl:px-40">
            <span class="flex w-14 h-1 bg-first mb-2"></span>
            <h1 class="font-bebas text-white text-5xl leading-none">Transformaciones</h1>
            <p class="font-poppins text-sm text-white"><span class="text-first">+</span>antes y después</p>
            <p class="font-poppins text-secondary text-sm mt-5">Resultados reales de nuestras obras</p>
            <div class="pt-10 flex items-center gap-3">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                    <path d="M8 12h8M8 12l3-3M8 12l3 3" stroke="#EB192E" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M16 12l-3-3M16 12l-3 3" stroke="#EB192E" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <p class="font-poppins text-secondary/60 text-xs">Arrastrá el divisor para comparar antes y después</p>
            </div>
        </div>
    </div>

    <!-- Filter bar -->
    <div class="bg-white border-b border-gray-200 px-5 md:px-20 xl:px-40 py-4 overflow-x-auto">
        <div class="flex gap-2 min-w-max">
            {allCategories.map((cat) => (
                <button
                    class="filter-btn font-poppins text-xs px-4 py-2 border transition-colors"
                    data-filter={cat}
                >
                    {cat}
                </button>
            ))}
        </div>
    </div>

    <!-- Grid -->
    <div id="transformaciones-grid" class="px-5 md:px-20 xl:px-40 py-8 grid grid-cols-1 md:grid-cols-2 gap-6">
        {transformaciones.map((t, i) => (
            <div class="trans-card flex flex-col gap-3" data-category={t.category}>
                <div class="flex items-baseline justify-between">
                    <div class="flex items-baseline gap-3">
                        <span class="font-bebas text-first text-sm tracking-widest">{t.number}</span>
                        <h2 class="font-bebas text-third text-2xl">{t.title}</h2>
                    </div>
                    <span class="font-poppins text-third/40 text-xs border border-gray-200 px-2 py-0.5">{t.category}</span>
                </div>

                <div
                    class="comparison-slider relative w-full h-72 overflow-hidden cursor-ew-resize select-none"
                    data-slider={i}
                >
                    <Image
                        src={t.after}
                        alt={`Después de ${t.title.toLowerCase()} - González Obras`}
                        width={800}
                        class="img-after absolute inset-0 w-full h-full object-cover pointer-events-none"
                        loading="lazy"
                    />
                    <Image
                        src={t.before}
                        alt={`Antes de ${t.title.toLowerCase()} - González Obras`}
                        width={800}
                        class="img-before absolute inset-0 w-full h-full object-cover pointer-events-none"
                        style="clip-path: inset(0 50% 0 0)"
                        loading="lazy"
                    />

                    <span class="absolute bottom-3 left-3 z-20 font-bebas text-white/70 text-xs tracking-widest bg-black/40 px-2 py-0.5">ANTES</span>
                    <span class="absolute bottom-3 right-3 z-20 font-bebas text-white/70 text-xs tracking-widest bg-black/40 px-2 py-0.5">DESPUÉS</span>

                    <div class="slider-handle absolute top-0 bottom-0 z-30 pointer-events-none" style="left: 50%; transform: translateX(-50%)">
                        <div class="absolute inset-0 left-1/2 w-px bg-white/80 -translate-x-1/2"></div>
                        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-10 h-10 bg-white rounded-full shadow-lg flex items-center justify-center pointer-events-auto cursor-ew-resize">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                                <path d="M8 12h8M8 12l3-3M8 12l3 3" stroke="#EB192E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                <path d="M16 12l-3-3M16 12l-3 3" stroke="#EB192E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </div>
                    </div>
                </div>
            </div>
        ))}
    </div>

    <!-- Empty state -->
    <div id="no-results" class="hidden py-16 text-center px-5">
        <p class="font-bebas text-gray-300 text-3xl">Sin resultados</p>
        <p class="font-poppins text-gray-400 text-sm mt-2">No hay transformaciones con esa categoría.</p>
    </div>

    <!-- CTA -->
    <div class="bg-[#0d0d0d] px-5 md:px-20 xl:px-40 py-14 flex flex-col items-center gap-4 border-t border-white/10">
        <span class="flex w-14 h-1 bg-first mb-1"></span>
        <p class="font-bebas text-white text-3xl text-center leading-tight">¿QUERÉS UNA TRANSFORMACIÓN ASÍ?</p>
        <p class="font-poppins text-secondary/70 text-sm text-center max-w-xs">Contanos tu proyecto y te mandamos un presupuesto sin compromiso.</p>
        <ButtonRed href="https://wa.me/3329335202?text=Hola%2C%20quiero%20consultar%20por%20un%20presupuesto" text="PEDIR PRESUPUESTO" size="lg" target="_blank" class="mt-1" />
        <a href="/proyectos" class="font-poppins text-white text-xs hover:text-white/70 transition">
            Ver nuestros <span class="underline">proyectos</span> →
        </a>
    </div>

    <Footer fadeStyle="linear-gradient(to bottom, #0d0d0d 0%, rgba(235,25,46,1) 100%)" />
</Layout>

<script>
    // Filter logic
    const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const cards = document.querySelectorAll<HTMLElement>('.trans-card');
    const noResults = document.getElementById('no-results')!;

    function applyFilter(filter: string) {
        filterBtns.forEach(btn => {
            const isActive = btn.dataset.filter === filter;
            btn.classList.toggle('bg-first', isActive);
            btn.classList.toggle('text-white', isActive);
            btn.classList.toggle('border-first', isActive);
            btn.classList.toggle('text-gray-500', !isActive);
            btn.classList.toggle('border-gray-200', !isActive);
            btn.classList.toggle('bg-white', !isActive);
        });

        let visible = 0;
        cards.forEach(card => {
            const show = filter === 'Todos' || card.dataset.category === filter;
            card.style.display = show ? '' : 'none';
            if (show) visible++;
        });

        noResults.classList.toggle('hidden', visible > 0);
    }

    filterBtns.forEach(btn => {
        btn.addEventListener('click', () => applyFilter(btn.dataset.filter ?? 'Todos'));
    });

    applyFilter('Todos');

    // Comparison slider logic
    const sliders = document.querySelectorAll<HTMLElement>('.comparison-slider');

    sliders.forEach(container => {
        const beforeImg = container.querySelector<HTMLElement>('.img-before')!;
        const handle = container.querySelector<HTMLElement>('.slider-handle')!;
        let isDragging = false;

        function setPosition(clientX: number) {
            const rect = container.getBoundingClientRect();
            const pct = Math.max(0, Math.min(100, ((clientX - rect.left) / rect.width) * 100));
            beforeImg.style.clipPath = `inset(0 ${100 - pct}% 0 0)`;
            handle.style.left = `${pct}%`;
        }

        container.addEventListener('mousedown', (e) => { isDragging = true; setPosition(e.clientX); });
        document.addEventListener('mousemove', (e) => { if (isDragging) setPosition(e.clientX); });
        document.addEventListener('mouseup', () => { isDragging = false; });

        container.addEventListener('touchstart', (e) => { isDragging = true; setPosition(e.touches[0].clientX); }, { passive: true });
        document.addEventListener('touchmove', (e) => { if (isDragging) setPosition(e.touches[0].clientX); }, { passive: true });
        document.addEventListener('touchend', () => { isDragging = false; });
    });
</script>
