---
import Navbar from '../components/Navbar.astro';
import Main from '../components/sections/Main.astro';
import Proyectos from '../components/sections/Proyectos.astro';
import Transformaciones from '../components/sections/Transformaciones.astro';
import Layout from '../layouts/Layout.astro';
import Servicios from '../components/sections/Servicios.astro'
import WhatsappButton from '../components/WhatsappButton.astro'
import Contacto from '../components/sections/Contacto.astro';
import FormularioContacto from '../components/sections/FormularioContacto.astro';
import Footer from '../components/sections/Footer.astro';

---

<Layout
	title="González Obras | Construcción en Seco en San Pedro, Buenos Aires"
	description="González Obras: más de 8 años en construcción en seco. Wall panel, cielorrasos, PVC, steel frame, revestimientos y amoblamientos a medida en San Pedro, Buenos Aires. Atendemos CABA, provincia de Buenos Aires y Rosario."
>
	<Navbar />
	<Main />
	<Proyectos />
	<Transformaciones />
	<Servicios />
	<div class="relative md:flex md:mb-10 md:pb-5 lg:px-20 xl:px-40 lg:gap-10 lg:mb-10 lg:mt-0 pt-2 lg:pt-0">
		<Contacto />
		<FormularioContacto />
	</div>
	<Footer />

	<script type="application/ld+json" set:html={JSON.stringify({
		"@context": "https://schema.org",
		"@type": "LocalBusiness",
		"name": "González Obras",
		"description": "Especialistas en construcción en seco. Wall panel, cielorrasos, PVC, steel frame, revestimientos y amoblamientos a medida.",
		"url": "https://gonzalezobras.com",
		"telephone": "+543329335202",
		"email": "facundo@gonzalezobras.com",
		"address": {
			"@type": "PostalAddress",
			"addressLocality": "San Pedro",
			"addressRegion": "Buenos Aires",
			"addressCountry": "AR"
		},
		"areaServed": [
			{ "@type": "City", "name": "San Pedro" },
			{ "@type": "State", "name": "Buenos Aires" },
			{ "@type": "City", "name": "Buenos Aires (CABA)" },
			{ "@type": "City", "name": "Rosario" }
		],
		"sameAs": [
			"https://instagram.com/GonzalezObras",
			"https://facebook.com/FacundoGonzalez"
		],
		"priceRange": "$$",
		"openingHoursSpecification": {
			"@type": "OpeningHoursSpecification",
			"dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
			"opens": "08:00",
			"closes": "18:00"
		}
	})} />
</Layout>
