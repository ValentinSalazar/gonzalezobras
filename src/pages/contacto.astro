---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/sections/Footer.astro';
import ContactoSection from '../components/sections/Contacto.astro';
import FormularioContacto from '../components/sections/FormularioContacto.astro';
---

<Layout
    title="Contacto | González Obras - Pedí tu Presupuesto en San Pedro, Buenos Aires"
    description="Contactá a González Obras para tu proyecto de construcción en seco. Presupuestos sin cargo en San Pedro, Buenos Aires, CABA y Rosario. Respondemos en menos de 24 horas."
>
    <Navbar />

    <!-- Hero -->
    <div class="relative h-80 overflow-hidden bg-[#111]">
        <div class="absolute inset-0 bg-black/60"></div>
        <div class="absolute top-32 left-0 right-0 z-10 px-5 md:px-20">
            <span class="flex w-14 h-1 bg-first mb-2"></span>
            <h1 class="font-bebas text-white text-5xl leading-none">Contacto</h1>
            <p class="font-poppins text-white text-sm"><span class="text-first">+</span>hablemos de tu proyecto</p>
        </div>
    </div>

    <div class="md:flex">
        <ContactoSection />
        <FormularioContacto />
    </div>

    <Footer />
</Layout>
